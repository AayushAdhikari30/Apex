# APEX v3 Environment Variables
# Copy this to .env.local and fill in values

# CoinGecko API (free tier works — https://www.coingecko.com/api)
NEXT_PUBLIC_COINGECKO_API_KEY=

# ExchangeRate API for Gold (free — https://www.exchangerate-api.com)
NEXT_PUBLIC_EXCHANGERATE_API_KEY=

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=APEX
NEXT_PUBLIC_APP_VERSION=3.0.0

# Optional: Alpha Vantage for stocks/ETFs (free tier)
NEXT_PUBLIC_ALPHAVANTAGE_API_KEY=
